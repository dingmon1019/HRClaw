APP_NAME=Win Agent Runtime
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

DATABASE_PATH=data/win_agent_runtime.db
AUDIT_LOG_PATH=data/audit/audit.jsonl
JSON_AUDIT_ENABLED=true
WORKSPACE_ROOT=workspace

RUNTIME_MODE=safe
ALLOWED_FILESYSTEM_ROOTS=workspace
ALLOWED_HTTP_HOSTS=example.com
ALLOWED_HTTP_SCHEMES=http,https
ALLOWED_HTTP_PORTS=80,443,8000,8080,11434
ALLOW_HTTP_PRIVATE_NETWORK=false
HTTP_FOLLOW_REDIRECTS=false
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RESPONSE_BYTES=1048576
ENABLE_SYSTEM_CONNECTOR=true
ENABLE_OUTLOOK_CONNECTOR=false

PROVIDER=mock
FALLBACK_PROVIDER=mock
MODEL=mock-model
BASE_URL=
API_KEY_ENV=OPENAI_API_KEY
GENERIC_HTTP_ENDPOINT=
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=2
PROVIDER_CIRCUIT_BREAKER_THRESHOLD=3
PROVIDER_CIRCUIT_BREAKER_SECONDS=60
SUMMARY_PROFILE=fast
PLANNING_PROFILE=strong
FAST_PROVIDER=mock
CHEAP_PROVIDER=mock
STRONG_PROVIDER=openai
LOCAL_PROVIDER=mock

SESSION_COOKIE_NAME=win_agent_session
SESSION_MAX_AGE_SECONDS=3600
RECENT_AUTH_WINDOW_SECONDS=300
SECURE_COOKIES=false
MAX_REQUEST_SIZE_BYTES=1048576
TRUSTED_HOSTS=127.0.0.1,localhost

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
