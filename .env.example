APP_NAME=Win Agent Runtime
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
DATABASE_PATH=data/win_agent_runtime.db
AUDIT_LOG_PATH=data/audit/audit.jsonl
JSON_AUDIT_ENABLED=true
RUNTIME_MODE=safe
ALLOWED_FILESYSTEM_ROOTS=.
ALLOWED_HTTP_HOSTS=127.0.0.1,localhost
POWERSHELL_ALLOWLIST=Get-ChildItem,Get-Content,Test-Path,Resolve-Path,Get-Date
PROVIDER=mock
FALLBACK_PROVIDER=mock
MODEL=mock-model
BASE_URL=
API_KEY_ENV=OPENAI_API_KEY
GENERIC_HTTP_ENDPOINT=
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

